{
  "manifest_version": 3,
  "name": "Recall Capture",
  "version": "0.1.0",
  "description": "Save selected web context and a personal note to the local Recall app.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8765/*"
  ],
  "action": {
    "default_title": "Save to Recall",
    "default_popup": "src/popup/popup.html"
  }
}
