# OpenAI
# Keep the real key only in .env or the shell environment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Mema backend
MEMA_HOST=127.0.0.1
MEMA_PORT=8765
MEMA_DATABASE_PATH=./data/mema.db
# Original image-note files. Defaults to an attachments directory beside the DB.
MEMA_ATTACHMENTS_PATH=./data/attachments
MEMA_LOG_LEVEL=INFO

# Comma-separated origins. Add the unpacked Chrome extension origin after its
# development ID is known. Do not use * in the submitted build.
MEMA_CORS_ORIGINS=
